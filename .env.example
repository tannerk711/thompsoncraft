# Thompson Craft LLC - Environment Variables
# Copy this file to .env.local and fill in your values

# ── Cloudinary (Photo Upload in Quote Wizard) ────────────────────────
# Create an upload preset per client in your Cloudinary dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=thompson-craft-uploads

# ── Zapier (Lead Routing to CRM) ─────────────────────────────────────
# Create a new Zap per client with a Webhooks trigger
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/

# ── Anthropic (AI Photo Estimate) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

